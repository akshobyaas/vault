# ─────────────────────────────────────────────
#  MY VAULT — Environment Variables
#  Copy this file, rename to .env, fill in your values
#  NEVER commit .env to GitHub
# ─────────────────────────────────────────────

# Your Google Sheet ID
# Found in the sheet URL: docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google Cloud API Key (restricted to Sheets API)
GOOGLE_API_KEY=your_api_key_here

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Refresh token (generated once via OAuth playground)
GOOGLE_REFRESH_TOKEN=your_refresh_token_here
